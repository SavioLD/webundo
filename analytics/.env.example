# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Datenbank ─────────────────────────────────────────────────────────────
# Pfad zur SQLite-Datei. ":memory:" für flüchtige Tests.
DATABASE_PATH=./data/analytics.db

# ── Auth ──────────────────────────────────────────────────────────────────
# WICHTIG: In Produktion durch ein langes, zufälliges Secret ersetzen!
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=12h

# ── Datenschutz ───────────────────────────────────────────────────────────
# Salt-Rotation für die tägliche Besucher-Hash-Ableitung (Basiswert).
VISITOR_SALT=change-me-too-random-secret
# Standard-Aufbewahrungsdauer für Rohdaten in Tagen (pro Website überschreibbar).
DEFAULT_RETENTION_DAYS=180

# ── Ingestion ─────────────────────────────────────────────────────────────
# Maximale Payload-Größe des öffentlichen Event-Endpunkts.
MAX_EVENT_PAYLOAD_KB=64
# Rate-Limit pro IP (Requests / Fenster) für den Event-Endpunkt.
INGEST_RATE_LIMIT=120
INGEST_RATE_WINDOW_MS=60000

# ── CORS ──────────────────────────────────────────────────────────────────
# Erlaubte Origins für das Dashboard-API (kommagetrennt). "*" nur für Dev.
DASHBOARD_CORS_ORIGINS=http://localhost:4000
